{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm --prefix web ci && npm --prefix web run build && npm --prefix tunnel ci && npm --prefix tunnel run build"
  },
  "deploy": {
    "startCommand": "npm --prefix tunnel start",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
